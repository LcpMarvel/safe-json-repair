# Rust
/target
/fuzz/target
/fuzz/corpus
/fuzz/artifacts
Cargo.lock.bak

# Node / npm package (bindings/js) — match at any depth
node_modules/
dist/
*.tsbuildinfo
*.tgz
npm-debug.log*

# Generated wasm bindings (rebuilt by `npm run build:wasm`)
bindings/js/src/generated/
bindings/js/.wasm-build/

# Python package (bindings/python) — maturin/venv build artifacts
# (dist/ is already ignored above; the binding shares the root workspace lock)
bindings/python/.venv/
bindings/python/target/
bindings/python/Cargo.lock
__pycache__/
*.so
.pytest_cache/
*.egg-info/

# Claude Code local state
.claude/scheduled_tasks.lock

# macOS
.DS_Store
